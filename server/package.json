{
  "name": "saferoots-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":   "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed":  "ts-node src/seed.ts"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "socket.io":          "^4.7.4",
    "uuid":               "^9.0.1"
  },
  "devDependencies": {
    "@types/cors":           "^2.8.17",
    "@types/express":        "^4.17.21",
    "@types/jsonwebtoken":   "^9.0.9",
    "@types/node":           "^22.0.0",
    "@types/uuid":           "^9.0.8",
    "nodemon":               "^3.0.3",
    "ts-node":               "^10.9.2",
    "typescript":            "^5.3.3"
  }
